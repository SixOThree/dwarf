root = false

[*]
charset = utf-8
end_of_line = lf
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cs,csx}]
indent_size = 4

[*.{csproj,props,targets,xml,axaml,xaml}]
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

# --- C# style ---
[*.cs]

# Namespace style: file-scoped (modern .NET convention)
csharp_style_namespace_declarations = file_scoped:warning

# var preferences: use var when type is apparent
csharp_style_var_for_built_in_types = false:silent
csharp_style_var_when_type_is_apparent = true:silent
csharp_style_var_elsewhere = false:silent

# Modern expressions
csharp_style_expression_bodied_methods = when_on_single_line:silent
csharp_style_expression_bodied_properties = when_on_single_line:silent
csharp_style_pattern_matching_over_is_with_cast_check = true:warning
csharp_style_pattern_matching_over_as_with_null_check = true:warning

# this. qualifier — discouraged
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
dotnet_style_qualification_for_event = false:warning

# Naming: private fields can be _camelCase OR camelCase (port has both)
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_camel_case
dotnet_naming_rule.private_fields_underscore.severity = silent

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_style.underscore_camel_case.required_prefix = _
dotnet_naming_style.underscore_camel_case.capitalization = camel_case

# Allow opcode field names that mirror Java: OPC_xA2_REC, ESC_x24_BNDCKL, etc.
# These violate UPPER_SNAKE_CASE conventions for constants but preserve traceability.
dotnet_diagnostic.IDE1006.severity = silent

# Disable XML doc warnings — port is internal, doc comments not required
dotnet_diagnostic.CS1591.severity = none

# Allow regions (some legacy structures benefit)
dotnet_diagnostic.IDE0064.severity = silent

# --- Suppressions for the Java->C# port ---
# The port preserves Java identifier names verbatim for traceability with the
# upstream Java source. The following analyzer rules conflict with this and
# are silenced project-wide.
dotnet_diagnostic.CA1707.severity = none   # Identifiers should not contain underscores
dotnet_diagnostic.CA1051.severity = none   # Do not declare visible instance fields
dotnet_diagnostic.CA2211.severity = none   # Non-constant fields should not be visible
dotnet_diagnostic.CA1815.severity = none   # Override equals on value types (Mesa structs are not value-types in port)
dotnet_diagnostic.CA1819.severity = none   # Properties should not return arrays (Mesa memory IS an array)
dotnet_diagnostic.CA1822.severity = silent # Mark members as static (refactor pass later, not now)
dotnet_diagnostic.CA1305.severity = silent # Specify IFormatProvider (defer; emulator logging is ASCII)
dotnet_diagnostic.CA1310.severity = silent # Specify StringComparison
dotnet_diagnostic.CA1304.severity = silent # Specify CultureInfo
dotnet_diagnostic.CA2208.severity = silent # Argument exception parameter names
dotnet_diagnostic.CA1710.severity = silent # Exception types named without 'Exception' suffix (MesaTrap, MesaERROR, etc.)
dotnet_diagnostic.CA1715.severity = silent # Interface names without 'I' prefix (MesaFaultTrapThrower)
dotnet_diagnostic.CA1716.severity = silent # 'ERROR' conflicts with VB keyword (C#-only project)
dotnet_diagnostic.CA1720.severity = silent # Identifiers containing type names ('pointer' parameter)
dotnet_diagnostic.CA1309.severity = silent # Ordinal string comparison (default Java semantics)
dotnet_diagnostic.CA1859.severity = silent # Return concrete type (perf hint — not critical here)
dotnet_diagnostic.CA1805.severity = silent # Explicit initialization to default value

# Dead code from `if (Config.LOG_*)` blocks. The const flags allow JIT
# to eliminate the bodies, which the compiler flags as unreachable. Intentional.
dotnet_diagnostic.CS0162.severity = silent

